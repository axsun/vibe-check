# ── Vibe Check env ──────────────────────────────────────────────
# All keys are read SERVER-SIDE only (see server/lib/*). Never commit real values.
# The app runs fully WITHOUT any of these (in-memory mock + mock analyzer).
# Fill them in to go live.

# Gemini 2.0 Flash — audio vibe analysis (https://aistudio.google.com/apikey)
GEMINI_API_KEY=

# Supabase — Project Settings -> API
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_BUCKET=clips

# ElevenLabs — TTS "Vibe Narrator"
ELEVENLABS_API_KEY=
# Optional: pick a voice id from https://elevenlabs.io/app/voice-library (defaults to "Rachel")
ELEVENLABS_VOICE_ID=

# Server
PORT=3001

# Override analyzer model (default gemini-2.5-flash)
GEMINI_MODEL=

# Google Maps JS API key — client-side, exposed to browser. Restrict by HTTP referrer in GCP.
# https://console.cloud.google.com/apis/credentials  (enable Maps JavaScript API)
VITE_GOOGLE_MAPS_API_KEY=
# Optional: cloud-styled Map ID for AdvancedMarkers + dark theme
# https://console.cloud.google.com/google/maps-apis/studio/maps
VITE_GOOGLE_MAPS_MAP_ID=
